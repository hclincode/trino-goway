# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# macOS
.DS_Store

# Local Claude tooling — share .claude/settings.json, keep personal overrides local
.claude/settings.local.json
# Per-project channel state (Telegram bot token, pairing/allowlist, inbox) — never commit
.claude/channels/

# Compiled binaries (built locally). Anchored to repo root with a leading "/"
# so they do not also ignore same-named directories like cmd/trino-goway or
# charts/trino-goway.
/goway-migrate-config
/goway-diff-harness
/mock-external-router
/mock-external-router-grpc
/trino-goway

# Helm chart vendored dependencies. Chart.lock is committed (pins resolved
# versions); the downloaded subchart .tgz + unpacked dir are fetched on demand
# via `helm dependency build` (CI and local), so they are not tracked.
charts/*/charts/

# Web UI build output copied into the Go embed dir by `make webapp`.
# Only the .gitkeep is tracked; the built bundle (index.html, assets, logo) is
# generated and served from the embed dir, with a placeholder fallback in code.
cmd/trino-goway/web/dist/index.html
cmd/trino-goway/web/dist/assets/
cmd/trino-goway/web/dist/logo.svg
webapp/dist/
